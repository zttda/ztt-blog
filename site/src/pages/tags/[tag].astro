---
import { Image } from 'astro:assets';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { getPublishedPosts } from '../../utils/posts';

export async function getStaticPaths() {
	const posts = await getPublishedPosts();
	const tags = [...new Set(posts.flatMap((post) => post.data.tags))];

	return tags.map((tag) => ({
		params: { tag },
		props: {
			tag,
			posts: posts
				.filter((post) => post.data.tags.includes(tag))
				.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
		},
	}));
}

const { tag, posts } = Astro.props;
const isXianxiaReference = (src: unknown) =>
	typeof src === 'object' && src !== null && 'src' in src && String(src.src).includes('ai-xianxia-reference');
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`${tag} | ${SITE_TITLE}`} description={`标签 ${tag} 下的文章。`} schemaType="collection" />
		<style>
			.tag-topic {
				width: min(1040px, calc(100% - 2rem));
			}

			.tag-topic-hero {
				position: relative;
				border: 2px solid rgba(var(--line), 0.76);
				border-radius: 28px;
				background:
					linear-gradient(120deg, rgba(var(--surface), 0.96), rgba(var(--surface-subtle), 0.74)),
					repeating-linear-gradient(0deg, transparent 0 31px, rgba(var(--accent-rgb), 0.08) 31px 32px);
				padding: clamp(1.4rem, 4vw, 2.75rem);
				overflow: hidden;
				box-shadow: var(--shadow);
			}

			.tag-topic-hero::after {
				position: absolute;
				top: -3.2rem;
				right: -2.2rem;
				width: 11rem;
				height: 11rem;
				border: 2rem solid rgba(var(--accent-rgb), 0.08);
				border-radius: 50%;
				content: '';
			}

			.tag-topic-breadcrumb {
				position: relative;
				z-index: 1;
				display: flex;
				flex-wrap: wrap;
				gap: 0.45rem;
				align-items: center;
				margin-bottom: clamp(1.6rem, 4vw, 2.8rem);
				color: rgb(var(--muted));
				font-size: 0.88rem;
				font-weight: 700;
			}

			.tag-topic-breadcrumb a {
				text-decoration: none;
			}

			.tag-topic-heading {
				position: relative;
				z-index: 1;
				display: grid;
				grid-template-columns: minmax(0, 1fr) auto;
				gap: 1.5rem;
				align-items: end;
			}

			.tag-topic-heading h1 {
				max-width: 46rem;
				margin: 0;
				font-size: clamp(2.65rem, 8vw, 5rem);
				line-height: 0.96;
				overflow-wrap: anywhere;
			}

			.tag-topic-heading h1 span {
				margin-right: 0.08em;
				color: var(--accent);
			}

			.tag-topic-count {
				display: grid;
				min-width: 8.5rem;
				min-height: 6.8rem;
				place-content: center;
				border: 2px solid rgba(var(--accent-rgb), 0.2);
				border-radius: 18px;
				background: rgba(var(--surface), 0.78);
				color: rgb(var(--muted));
				font-size: 0.82rem;
				font-weight: 700;
				text-align: center;
				box-shadow: 4px 5px 0 rgba(var(--accent-rgb), 0.1);
			}

			.tag-topic-count strong {
				display: block;
				margin-bottom: 0.18rem;
				color: var(--accent);
				font-family: var(--font-heading);
				font-size: 2.25rem;
				line-height: 1;
			}

			.tag-topic-section {
				margin-top: clamp(2.6rem, 6vw, 4.5rem);
			}

			.tag-topic-section-head {
				display: flex;
				gap: 1rem;
				align-items: end;
				justify-content: space-between;
				margin-bottom: 1.25rem;
				border-bottom: 1px dashed rgba(var(--line), 0.86);
				padding-bottom: 0.9rem;
			}

			.tag-topic-section-head h2 {
				margin: 0;
				font-size: clamp(1.65rem, 4vw, 2.45rem);
			}

			.tag-topic-section-head p {
				margin: 0;
				color: rgb(var(--muted));
				font-size: 0.9rem;
			}

			.tag-topic-list {
				display: grid;
				gap: 1rem;
			}

			.tag-topic-entry {
				position: relative;
				display: grid;
				grid-template-columns: 3.25rem minmax(0, 1fr) 2.5rem;
				gap: 1rem;
				align-items: center;
				border: 2px solid rgba(var(--line), 0.74);
				border-radius: 22px;
				background:
					repeating-linear-gradient(0deg, transparent 0 30px, rgba(var(--accent-rgb), 0.05) 30px 31px),
					rgba(var(--surface), 0.9);
				color: inherit;
				padding: 1rem;
				text-decoration: none;
				box-shadow: var(--shadow-soft);
				transition:
					transform 180ms ease,
					border-color 180ms ease,
					box-shadow 180ms ease;
			}

			.tag-topic-entry.has-image {
				grid-template-columns: 3.25rem minmax(210px, 0.72fr) minmax(0, 1.28fr) 2.5rem;
			}

			.tag-topic-entry:hover {
				border-color: rgba(var(--accent-rgb), 0.48);
				box-shadow: var(--shadow);
				transform: translateY(-3px);
			}

			.tag-topic-entry__index {
				align-self: stretch;
				display: flex;
				align-items: flex-start;
				justify-content: center;
				border-right: 1px dashed rgba(var(--line), 0.86);
				padding-top: 0.3rem;
				color: var(--accent);
				font-family: var(--font-heading);
				font-size: 0.88rem;
				font-weight: 700;
				letter-spacing: 0.1em;
			}

			.tag-topic-entry__media {
				overflow: hidden;
				border: 2px solid rgba(var(--line), 0.68);
				border-radius: 16px;
				background: rgb(var(--surface-subtle));
				box-shadow: 3px 4px 0 rgba(var(--accent-rgb), 0.09);
			}

			.tag-topic-entry__media :global(img) {
				display: block;
				width: 100%;
				aspect-ratio: 16 / 9;
				border: 0;
				border-radius: 0;
				object-fit: cover;
				box-shadow: none;
			}

			.tag-topic-entry__media :global(img[src*='ai-xianxia-reference']) {
				object-position: center top;
			}

			.tag-topic-entry__content {
				min-width: 0;
			}

			.tag-topic-entry__date {
				margin-bottom: 0.4rem;
				color: rgb(var(--muted));
				font-size: 0.82rem;
				font-weight: 700;
			}

			.tag-topic-entry h3 {
				margin-bottom: 0.55rem;
				font-size: clamp(1.35rem, 3vw, 1.9rem);
			}

			.tag-topic-entry__description {
				display: -webkit-box;
				margin: 0;
				color: rgb(var(--muted));
				font-size: 0.94rem;
				line-height: 1.6;
				overflow: hidden;
				-webkit-box-orient: vertical;
				-webkit-line-clamp: 2;
			}

			.tag-topic-entry__arrow {
				display: inline-flex;
				width: 2.3rem;
				height: 2.3rem;
				align-items: center;
				justify-content: center;
				border-radius: 999px;
				background: var(--accent-soft);
				color: var(--accent);
				font-size: 1.2rem;
				transition: transform 180ms ease;
			}

			.tag-topic-entry:hover .tag-topic-entry__arrow {
				transform: translateX(3px);
			}

			@media (max-width: 820px) {
				.tag-topic-entry.has-image {
					grid-template-columns: 2.75rem minmax(170px, 0.78fr) minmax(0, 1.22fr) 2.3rem;
					gap: 0.75rem;
				}
			}

			@media (max-width: 680px) {
				.tag-topic {
					width: min(100% - 1.2rem, 1040px);
				}

				.tag-topic-hero {
					border-radius: 22px;
				}

				.tag-topic-heading {
					grid-template-columns: 1fr;
				}

				.tag-topic-count {
					min-width: 0;
					width: min(100%, 12rem);
					min-height: 5.4rem;
				}

				.tag-topic-section-head {
					align-items: flex-start;
					flex-direction: column;
					gap: 0.35rem;
				}

				.tag-topic-entry,
				.tag-topic-entry.has-image {
					grid-template-columns: 2.5rem minmax(0, 1fr) 2.2rem;
				}

				.tag-topic-entry__media {
					grid-column: 2 / -1;
					grid-row: 1;
				}

				.tag-topic-entry.has-image .tag-topic-entry__index {
					grid-row: 1 / 3;
				}

				.tag-topic-entry.has-image .tag-topic-entry__content {
					grid-column: 2 / -1;
					grid-row: 2;
					padding-right: 3.25rem;
				}

				.tag-topic-entry.has-image .tag-topic-entry__arrow {
					position: absolute;
					right: 1rem;
					bottom: 1rem;
				}
			}

			@media (max-width: 420px) {
				.tag-topic-entry,
				.tag-topic-entry.has-image {
					grid-template-columns: 1fr;
				}

				.tag-topic-entry__index {
					display: none;
				}

				.tag-topic-entry__media,
				.tag-topic-entry.has-image .tag-topic-entry__media,
				.tag-topic-entry.has-image .tag-topic-entry__content {
					grid-column: 1;
					grid-row: auto;
				}
			}

			@media (prefers-reduced-motion: reduce) {
				.tag-topic-entry,
				.tag-topic-entry__arrow {
					transition: none;
				}

				.tag-topic-entry:hover,
				.tag-topic-entry:hover .tag-topic-entry__arrow {
					transform: none;
				}
			}

			@media (hover: none), (pointer: coarse) {
				.tag-topic-entry:hover,
				.tag-topic-entry:hover .tag-topic-entry__arrow {
					transform: none;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main id="main-content" class="tag-topic">
			<section class="tag-topic-hero" aria-labelledby="tag-topic-title">
				<nav class="tag-topic-breadcrumb" aria-label="面包屑">
					<a href="/tags/">全部标签</a>
					<span aria-hidden="true">/</span>
					<span aria-current="page">{tag}</span>
				</nav>
				<div class="tag-topic-heading">
					<div>
						<p class="eyebrow">Topic notebook · 主题手记</p>
						<h1 id="tag-topic-title"><span aria-hidden="true">#</span>{tag}</h1>
					</div>
					<div class="tag-topic-count" aria-label={`共有 ${posts.length} 篇文章`}>
						<strong>{posts.length}</strong>
						<span>篇公开文章</span>
					</div>
				</div>
			</section>

			<section class="tag-topic-section" aria-labelledby="tag-topic-list-title">
				<div class="tag-topic-section-head">
					<h2 id="tag-topic-list-title">这个主题下的记录</h2>
					<p>按发布日期从新到旧排列</p>
				</div>
				<div class="tag-topic-list">
					{posts.map((post, index) => (
						<a
							class:list={['tag-topic-entry', { 'has-image': Boolean(post.data.heroImage) }]}
							href={`/blog/${post.id}/`}
						>
							<span class="tag-topic-entry__index" aria-hidden="true">
								{String(index + 1).padStart(2, '0')}
							</span>
							{post.data.heroImage && (
								<div class="tag-topic-entry__media">
									<Image
										width={640}
										height={isXianxiaReference(post.data.heroImage) ? 480 : 360}
										widths={[320, 480, 640]}
										sizes="(max-width: 420px) calc(100vw - 3.5rem), (max-width: 680px) calc(100vw - 6rem), (max-width: 1040px) 32vw, 270px"
										src={post.data.heroImage}
										alt=""
										loading="lazy"
									/>
								</div>
							)}
							<div class="tag-topic-entry__content">
								<p class="tag-topic-entry__date"><FormattedDate date={post.data.pubDate} /></p>
								<h3>{post.data.title}</h3>
								<p class="tag-topic-entry__description">{post.data.description}</p>
							</div>
							<span class="tag-topic-entry__arrow" aria-hidden="true">→</span>
						</a>
					))}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
