---
import { Image } from 'astro:assets';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { getPublishedPosts } from '../../utils/posts';

export async function getStaticPaths() {
	const posts = await getPublishedPosts();
	const tags = [...new Set(posts.flatMap((post) => post.data.tags))];

	return tags.map((tag) => ({
		params: { tag },
		props: {
			tag,
			posts: posts
				.filter((post) => post.data.tags.includes(tag))
				.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
		},
	}));
}

const { tag, posts } = Astro.props;
const isXianxiaReference = (src: unknown) =>
	typeof src === 'object' && src !== null && 'src' in src && String(src.src).includes('ai-xianxia-reference');
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`${tag} | ${SITE_TITLE}`} description={`标签 ${tag} 下的文章。`} schemaType="collection" />
	</head>
	<body>
		<Header />
		<main id="main-content">
			<p class="eyebrow">Tag</p>
			<h1>{tag}</h1>
			<p class="page-lede">这个标签下共有 {posts.length} 篇文章。</p>

			<div class="grid">
				{
					posts.map((post) => (
						<a class="post-card" href={`/blog/${post.id}/`}>
							{post.data.heroImage && (
								<Image
									width={720}
									height={isXianxiaReference(post.data.heroImage) ? 540 : 405}
									widths={[360, 540, 720]}
									sizes="(max-width: 820px) calc(100vw - 3rem), (max-width: 1040px) 50vw, 33vw"
									src={post.data.heroImage}
									position={isXianxiaReference(post.data.heroImage) ? 'top' : undefined}
									alt=""
								/>
							)}
							<div>
								<p class="post-meta">
									<FormattedDate date={post.data.pubDate} />
								</p>
								<h2>{post.data.title}</h2>
								<p class="muted">{post.data.description}</p>
							</div>
						</a>
					))
				}
			</div>
		</main>
		<Footer />
	</body>
</html>
