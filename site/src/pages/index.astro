---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import HeroImage from '../assets/blog-placeholder-2.jpg';
import home from '../data/home.json';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getPublishedPosts } from '../utils/posts';

const posts = await getPublishedPosts();
const latestPosts = posts.slice(0, 3);
const allTags = [...new Set(posts.flatMap((post) => post.data.tags))].slice(0, 8);
const latestPostHref = latestPosts[0] ? `/blog/${latestPosts[0].id}/` : home.primaryHref;
const isXianxiaReference = (src: unknown) =>
	typeof src === 'object' && src !== null && 'src' in src && String(src.src).includes('ai-xianxia-reference');
const opacity = (value: unknown, fallback: number) => {
	const parsed = Number(value);
	if (Number.isNaN(parsed)) return fallback;
	return Math.min(1, Math.max(0, parsed));
};
const heroBackground = home.heroBackground;
const homeStyle = [
	heroBackground ? `--hero-bg: url('${heroBackground}')` : '',
	`--hero-overlay-start: ${opacity(home.heroOverlayStart, 0.72)}`,
	`--hero-overlay-end: ${opacity(home.heroOverlayEnd, 0.42)}`,
	`--hero-panel-opacity: ${opacity(home.heroPanelOpacity, 0.82)}`,
	`--primary-button-opacity: ${opacity(home.primaryButtonOpacity, 1)}`,
	`--secondary-button-opacity: ${opacity(home.secondaryButtonOpacity, 0.86)}`,
]
	.filter(Boolean)
	.join('; ');
const customSections = home.sections?.filter((section) => section.enabled) ?? [];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead
			title={SITE_TITLE}
			description={SITE_DESCRIPTION}
			image={HeroImage}
			schemaType="website"
			preloadHero={heroBackground
				? { desktop: heroBackground, mobile: '/uploads/theme/crayon-scene-mobile-720.webp' }
				: undefined}
		/>
	</head>
	<body>
		<Header />
		<main id="main-content">
			<section class:list={['hero', 'mobile-diary-hero', { 'has-bg': heroBackground }]} style={homeStyle}>
				<div class="hero-mobile-sticker" aria-hidden="true"></div>
				<div class="hero-copy">
					<p class="hero-kicker">{home.kicker}</p>
					<h1>{home.title || SITE_TITLE}</h1>
					<p>{home.description}</p>
					<div class="actions">
						<a class="button" href={latestPostHref}>{home.primaryLabel}</a>
						<a class="button secondary" href={home.secondaryHref}>{home.secondaryLabel}</a>
					</div>
				</div>
				<div class="hero-panel">
					<p class="eyebrow">{home.panelEyebrow}</p>
					<h2>{home.panelTitle}</h2>
					<p class="muted">{home.panelText}</p>
				</div>
				<div class="hero-scene-strip" aria-hidden="true"></div>
			</section>

			{home.showLatestPosts && (
				<section>
					<div class="section-head">
						<div>
							<p class="eyebrow">Latest</p>
							<h2>最近文章</h2>
						</div>
						<a href="/blog/">全部文章</a>
					</div>
					<div class="grid">
						{
							latestPosts.map((post) => (
								<a class="post-card" href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<Image
											width={720}
											height={isXianxiaReference(post.data.heroImage) ? 540 : 405}
											widths={[360, 540, 720]}
											sizes="(max-width: 820px) calc(100vw - 3rem), (max-width: 1040px) 50vw, 33vw"
											src={post.data.heroImage}
											position={isXianxiaReference(post.data.heroImage) ? 'top' : undefined}
											alt=""
										/>
									)}
									<div>
										<p class="post-meta">
											<FormattedDate date={post.data.pubDate} />
										</p>
										<h3>{post.data.title}</h3>
										<p class="muted">{post.data.description}</p>
										<div class="tag-list">
											{post.data.tags.slice(0, 3).map((tag) => (
												<span class="tag-pill">{tag}</span>
											))}
										</div>
									</div>
								</a>
							))
						}
					</div>
				</section>
			)}

			{customSections.map((section) => (
				<section class="custom-section">
					<div class="section-head">
						<div>
							<p class="eyebrow">{section.eyebrow}</p>
							<h2>{section.title}</h2>
						</div>
						{section.linkHref && section.linkLabel && <a href={section.linkHref}>{section.linkLabel}</a>}
					</div>
					<p class="page-lede">{section.body}</p>
				</section>
			))}

			{home.showTopics && (
				<section>
					<div class="section-head">
						<div>
							<p class="eyebrow">Topics</p>
							<h2>正在整理的主题</h2>
						</div>
						<a href="/tags/">全部标签</a>
					</div>
					<div class="tag-list">
						{allTags.map((tag) => <a class="tag-pill" href={`/tags/${encodeURIComponent(tag)}/`}>{tag}</a>)}
					</div>
				</section>
			)}
		</main>
		<Footer />
	</body>
</html>
