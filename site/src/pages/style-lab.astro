---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const styles = [
	{
		id: 'crayon-party',
		name: '蜡笔派对',
		tone: '保留当前方向',
		description: '最活泼，适合个人感很强、日记感强的博客。图可以多一点，但最好只保留首页大图和一张贴纸。',
		media: '/uploads/theme/crayon-sticker-360.webp',
	},
	{
		id: 'paper',
		name: '纸刊手记',
		tone: '暖纸、编辑感',
		description: '像一本整理过的手帐或独立杂志，颜色更稳，图片用少量便签式小图点到为止。',
		media: '/uploads/theme/paper-note.svg',
	},
	{
		id: 'ceramic',
		name: '陶瓷档案',
		tone: '青蓝、留白、红色小印章',
		description: '比蜡笔成熟，清爽但不冷，适合长期写学习记录、项目记录和生活小结。',
		media: '/uploads/theme/ceramic-motif.svg',
	},
	{
		id: 'noir',
		name: '夜读小报',
		tone: '深色、橙红、青色反差',
		description: '有一点夜晚阅读和小报感，比较有记忆点，但比黑底霓虹更克制。',
		media: '/uploads/theme/noir-window.svg',
	},
	{
		id: 'brutal',
		name: '粗野印刷',
		tone: '高对比、方块、硬边',
		description: '更像项目日志或实验记录，个性强，适合想让网站看起来不甜、不软的版本。',
		media: '/uploads/theme/paper-note.svg',
	},
	{
		id: 'terminal',
		name: '绿色终端',
		tone: '代码感、暗色、荧光绿',
		description: '技术感最强，适合偏工具、折腾、开发笔记的站点，图片基本变成小标识。',
		media: '/uploads/theme/terminal-card.svg',
	},
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`风格预览 | ${SITE_TITLE}`} description="集中查看博客的多套视觉风格方案。" />
	</head>
	<body>
		<Header />
		<main class="style-lab">
			<section class="style-lab-hero">
				<p class="eyebrow">Style Lab</p>
				<h1>先看几版，再定方向</h1>
				<p class="page-lede">
					这里把当前蜡笔版和几套不同色系的备选放在一起。每张卡片都可以点开首页预览，右下角圆形按钮也能随时切换。
				</p>
			</section>

			<section class="style-preview-grid" aria-label="风格候选">
				{
					styles.map((style) => (
						<a class="style-preview-card" href={`/?style=${style.id}`}>
							<img src={style.media} alt="" loading="lazy" />
							<div>
								<p class="eyebrow">{style.tone}</p>
								<h2>{style.name}</h2>
								<p>{style.description}</p>
								<span>看这一版</span>
							</div>
						</a>
					))
				}
			</section>
		</main>
		<Footer />
	</body>
</html>
