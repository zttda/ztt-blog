---
import { Image } from 'astro:assets';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { getPublishedPosts } from '../../utils/posts';

const posts = await getPublishedPosts();
const isXianxiaReference = (src: unknown) =>
	typeof src === 'object' && src !== null && 'src' in src && String(src.src).includes('ai-xianxia-reference');
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`文章 | ${SITE_TITLE}`} description="按时间查看 ztt 的博客文章。" schemaType="collection" />
	</head>
	<body>
		<Header />
		<main id="main-content">
			<p class="eyebrow">Blog</p>
			<h1>文章</h1>
			<p class="page-lede">这里会逐步放学习笔记、项目记录、工具折腾和阶段总结。</p>

			<div class="grid">
				{
					posts.map((post) => (
						<a class="post-card" href={`/blog/${post.id}/`}>
							{post.data.heroImage && (
								<Image
									width={720}
									height={isXianxiaReference(post.data.heroImage) ? 540 : 405}
									widths={[360, 540, 720]}
									sizes="(max-width: 820px) calc(100vw - 3rem), (max-width: 1040px) 50vw, 33vw"
									src={post.data.heroImage}
									position={isXianxiaReference(post.data.heroImage) ? 'top' : undefined}
									alt=""
								/>
							)}
							<div>
								<p class="post-meta">
									<FormattedDate date={post.data.pubDate} />
								</p>
								<h2>{post.data.title}</h2>
								<p class="muted">{post.data.description}</p>
								<div class="tag-list">
									{post.data.tags.map((tag) => (
										<span class="tag-pill">{tag}</span>
									))}
								</div>
							</div>
						</a>
					))
				}
			</div>
		</main>
		<Footer />
	</body>
</html>
