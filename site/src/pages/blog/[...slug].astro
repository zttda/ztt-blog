---
import { type CollectionEntry, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { getPublishedPosts } from '../../utils/posts';

type AdjacentPost = {
	title: string;
	href: string;
};

export async function getStaticPaths() {
	const postHref = (post: CollectionEntry<'blog'>) => `/blog/${post.id.replace(/\.mdx?$/, '')}/`;
	const toAdjacentPost = (post: CollectionEntry<'blog'>): AdjacentPost => ({
		title: post.data.title,
		href: postHref(post),
	});
	const posts = await getPublishedPosts();
	return posts.map((post, index) => ({
		params: { slug: post.id.replace(/\.mdx?$/, '') },
		props: {
			post,
			previousPost: index > 0 ? toAdjacentPost(posts[index - 1]) : undefined,
			nextPost: index < posts.length - 1 ? toAdjacentPost(posts[index + 1]) : undefined,
		},
	}));
}
type Props = {
	post: CollectionEntry<'blog'>;
	previousPost?: AdjacentPost;
	nextPost?: AdjacentPost;
};

const { post, previousPost, nextPost } = Astro.props;
const { Content } = await render(post);
---

<BlogPost {...post.data} previousPost={previousPost} nextPost={nextPost}>
	<Content />
</BlogPost>
