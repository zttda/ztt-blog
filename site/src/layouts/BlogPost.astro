---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	heroImageVariant?: 'wide' | 'square';
};

const { title, description, pubDate, updatedDate, heroImage, heroImageVariant = 'wide' } = Astro.props;
const heroSrc = heroImage?.src ?? '';
const isSquareHero = heroImageVariant === 'square' || heroSrc.includes('blog-xs.');
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		<style>
			main {
				width: min(1180px, calc(100% - 2em));
				max-width: 100%;
				margin: 0 auto;
				padding-top: 2rem;
			}
			.hero-image {
				width: min(1040px, 100%);
				margin: 0 auto 2rem;
			}
			.hero-image.hero-image--square {
				position: relative;
				width: min(620px, calc(100% - 2em));
				aspect-ratio: 1;
				margin: 1.5em auto 1.75em;
				overflow: hidden;
				border: 3px solid rgba(var(--surface), 0.92);
				border-radius: 24px;
				background:
					linear-gradient(180deg, rgba(var(--hero-wash), 0.08), rgba(var(--hero-wash), 0.18)),
					url("/uploads/theme/crayon-sticker-720.webp") center / cover no-repeat;
				box-shadow:
					0 0 0 2px var(--hero-frame),
					var(--shadow);
			}
			.hero-image img {
				display: block;
				width: 100%;
				margin: 0 auto;
				border: 3px solid rgba(var(--surface), 0.92);
				border-radius: 24px;
				box-shadow:
					0 0 0 2px var(--hero-frame),
					var(--shadow);
			}
			.hero-image.hero-image--square img {
				height: 100%;
				border: 0;
				border-radius: 0;
				box-shadow: none;
				object-fit: cover;
			}
			.prose {
				width: 760px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: clamp(1.2rem, 3vw, 2rem);
				color: rgb(var(--ink));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0 1.5em;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--muted));
			}
			.last-updated-on {
				font-style: italic;
			}
			@media (max-width: 820px) {
				main {
					width: min(100% - 1.2rem, 760px);
				}
				.hero-image.hero-image--square {
					width: min(560px, 92vw);
					margin: 1.2rem auto 1.4rem;
				}
			}
			@media (max-width: 520px) {
				main {
					box-sizing: border-box;
					width: 100%;
					max-width: 100vw;
					padding: 1.2rem 0.85rem 3.8rem;
					overflow-x: hidden;
				}
				article {
					width: 100%;
					max-width: 100%;
					overflow-x: hidden;
				}
				.hero-image {
					margin-bottom: 1.2rem;
				}
				.hero-image.hero-image--square {
					width: min(300px, 82vw);
					margin: 0.9rem auto 1.25rem;
				}
				.prose {
					box-sizing: border-box;
					width: min(340px, calc(100vw - 2rem));
					max-width: calc(100vw - 2rem);
					margin-right: auto;
					margin-left: 0;
					padding: 1rem;
					border-radius: 18px;
					overflow-wrap: anywhere;
				}
				.prose :global(*) {
					box-sizing: border-box;
					max-width: 100%;
					overflow-wrap: anywhere;
					word-break: break-word;
				}
				.title {
					margin-bottom: 0.8rem;
					padding: 0.75rem 0 1rem;
				}
				.title h1 {
					font-size: clamp(2rem, 10vw, 2.45rem);
					line-height: 1.08;
				}
				.title hr {
					opacity: 0.28;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class:list={['hero-image', { 'hero-image--square': isSquareHero }]}>
					{
						heroImage && (
							<Image
								width={isSquareHero ? 680 : 1020}
								height={isSquareHero ? 680 : 510}
								src={heroImage}
								loading="eager"
								fetchpriority="high"
								alt={`${title} 封面`}
							/>
						)
					}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										更新于 <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
