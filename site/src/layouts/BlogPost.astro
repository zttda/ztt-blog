---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = Omit<CollectionEntry<'blog'>['data'], 'draft'> & {
	draft?: boolean;
	heroImageVariant?: 'wide' | 'square';
	pageType?: 'article' | 'profile';
	previousPost?: {
		title: string;
		href: string;
	};
	nextPost?: {
		title: string;
		href: string;
	};
};

const {
	title,
	description,
	tags = [],
	pubDate,
	updatedDate,
	heroImage,
	heroImageVariant = 'wide',
	pageType = 'article',
	previousPost,
	nextPost,
} = Astro.props;
const heroSrc = heroImage?.src ?? '';
const isSquareHero =
	heroImageVariant === 'square' || heroSrc.includes('blog-xs.') || heroSrc.includes('ai-xianxia-reference.');
const isTopAlignedHero = heroSrc.includes('ai-xianxia-reference.');
---

<html lang="zh-CN">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={heroImage}
			type={pageType === 'article' ? 'article' : 'website'}
			schemaType={pageType}
			pubDate={pageType === 'article' ? pubDate : undefined}
			updatedDate={pageType === 'article' ? updatedDate : undefined}
			keywords={tags}
		/>
		<style>
			main {
				width: min(1120px, calc(100% - 2em));
				max-width: 100%;
				margin: 0 auto;
				padding-top: 2rem;
			}
			.hero-image {
				width: min(1040px, 100%);
				margin: 0 auto clamp(1.8rem, 4vw, 2.8rem);
			}
			.hero-image.hero-image--square {
				position: relative;
				width: min(620px, calc(100% - 2em));
				aspect-ratio: 1;
				margin: 1.5em auto 1.75em;
				overflow: hidden;
				border: 3px solid rgba(var(--surface), 0.92);
				border-radius: 24px;
				background:
					linear-gradient(180deg, rgba(var(--hero-wash), 0.08), rgba(var(--hero-wash), 0.18)),
					rgb(var(--surface-subtle));
				box-shadow:
					0 0 0 2px var(--hero-frame),
					var(--shadow);
			}
			.hero-image img {
				display: block;
				width: 100%;
				margin: 0 auto;
				border: 3px solid rgba(var(--surface), 0.92);
				border-radius: 24px;
				box-shadow:
					0 0 0 2px var(--hero-frame),
					var(--shadow);
			}
			.hero-image.hero-image--square img {
				height: 100%;
				border: 0;
				border-radius: 0;
				box-shadow: none;
				object-fit: cover;
			}
			.hero-image.hero-image--top img {
				object-position: center top;
			}
			.prose {
				width: 760px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: clamp(1.2rem, 3vw, 2rem);
				color: rgb(var(--ink));
			}
			.title {
				margin-bottom: 1.5rem;
				padding: 0.35rem 0 1.5rem;
				text-align: center;
			}
			.title h1 {
				margin: 0;
				line-height: 1.08;
			}
			.article-description {
				max-width: 42rem;
				margin: 0.85rem auto 0;
				color: rgb(var(--muted));
				font-family: var(--font-post-body);
				font-size: clamp(1rem, 1.4vw, 1.1rem);
				line-height: 1.7;
			}
			.back-to-blog {
				display: inline-flex;
				min-height: 2.75rem;
				align-items: center;
				margin-bottom: 0.9rem;
				font-weight: 700;
				text-decoration: none;
			}
			.article-meta {
				display: flex;
				flex-wrap: wrap;
				gap: 0.65rem 1rem;
				align-items: center;
				justify-content: center;
				margin-top: 1.1rem;
			}
			.article-meta .tag-list {
				justify-content: center;
				margin: 0;
			}
			.date {
				display: flex;
				flex-wrap: wrap;
				gap: 0.35rem 0.7rem;
				align-items: center;
				color: rgb(var(--muted));
			}
			.last-updated-on {
				font-style: italic;
			}
			.post-navigation {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1rem;
				margin-top: clamp(2.5rem, 6vw, 4rem);
				border-top: 1px solid rgba(var(--line), 0.86);
				padding-top: 1.25rem;
			}
			.post-navigation a {
				display: flex;
				min-height: 4.75rem;
				flex-direction: column;
				justify-content: center;
				border: 1px solid rgba(var(--line), 0.82);
				border-radius: 16px;
				background: rgba(var(--surface), 0.62);
				padding: 0.8rem 1rem;
				text-decoration: none;
				transition:
					transform 160ms ease,
					border-color 160ms ease,
					box-shadow 160ms ease;
			}
			.post-navigation a:hover {
				border-color: rgba(var(--accent-rgb), 0.48);
				box-shadow: var(--shadow-soft);
				transform: translateY(-2px);
			}
			.post-navigation__next {
				grid-column: 2;
				text-align: right;
			}
			.post-navigation__label {
				margin-bottom: 0.25rem;
				color: rgb(var(--muted));
				font-size: 0.88rem;
				font-weight: 600;
			}
			.post-navigation__title {
				color: var(--link);
				line-height: 1.45;
			}
			@media (max-width: 820px) {
				main {
					width: min(100% - 1.2rem, 760px);
				}
				.hero-image.hero-image--square {
					width: min(560px, 92vw);
					margin: 1.2rem auto 1.4rem;
				}
			}
			@media (max-width: 520px) {
				main {
					box-sizing: border-box;
					width: 100%;
					max-width: 100vw;
					padding: 1.2rem 0.85rem 3.8rem;
					overflow-x: hidden;
				}
				article {
					width: 100%;
					max-width: 100%;
					overflow-x: hidden;
				}
				.hero-image {
					margin-bottom: 1.2rem;
				}
				.hero-image.hero-image--square {
					width: min(300px, 82vw);
					margin: 0.9rem auto 1.25rem;
				}
				.prose {
					box-sizing: border-box;
					width: 100%;
					max-width: calc(100vw - 2rem);
					margin-inline: auto;
					padding: 1rem;
					border-radius: 18px;
					overflow-wrap: anywhere;
				}
				.prose :global(*) {
					box-sizing: border-box;
					max-width: 100%;
					overflow-wrap: anywhere;
					word-break: break-word;
				}
				.title {
					margin-bottom: 1.1rem;
					padding: 0.35rem 0 1rem;
				}
				.title h1 {
					font-size: clamp(2rem, 10vw, 2.45rem);
					line-height: 1.08;
				}
				.title hr {
					opacity: 0.28;
				}
				.article-meta {
					flex-direction: column;
				}
				.date {
					justify-content: center;
				}
				.post-navigation {
					grid-template-columns: 1fr;
				}
				.post-navigation__next {
					grid-column: 1;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main id="main-content">
			<article class="prose">
				{pageType === 'article' && <a class="back-to-blog" href="/blog/">← 返回文章列表</a>}
				<header class="title">
					<h1>{title}</h1>
					<p class="article-description">{description}</p>
					{pageType === 'article' && (
						<div class="article-meta">
							<div class="date">
								<FormattedDate date={pubDate} />
								{
									updatedDate && (
										<span class="last-updated-on">
											更新于 <FormattedDate date={updatedDate} />
										</span>
									)
								}
							</div>
							{tags.length > 0 && (
								<div class="tag-list" aria-label="文章标签">
									{
										tags.map((tag) => (
											<a class="tag-pill" href={`/tags/${encodeURIComponent(tag)}/`}>{tag}</a>
										))
									}
								</div>
							)}
						</div>
					)}
					<hr />
				</header>
				{
					heroImage && (
						<div
							class:list={[
								'hero-image',
								{ 'hero-image--square': isSquareHero, 'hero-image--top': isTopAlignedHero },
							]}
						>
							<Image
								width={isSquareHero ? 680 : 1020}
								height={isSquareHero ? 680 : 510}
								widths={isSquareHero ? [320, 480, 680] : [480, 760, 1020]}
								sizes={isSquareHero
									? '(max-width: 520px) 82vw, (max-width: 820px) 92vw, 620px'
									: '(max-width: 820px) calc(100vw - 2rem), 1020px'}
								src={heroImage}
								loading="eager"
								fetchpriority="high"
								alt=""
							/>
						</div>
					)
				}
				<slot />
				{
					pageType === 'article' && (previousPost || nextPost) && (
						<nav class="post-navigation" aria-label="相邻文章">
							{previousPost && (
								<a class="post-navigation__previous" href={previousPost.href} rel="prev">
									<span class="post-navigation__label">← 上一篇</span>
									<span class="post-navigation__title">{previousPost.title}</span>
								</a>
							)}
							{nextPost && (
								<a class="post-navigation__next" href={nextPost.href} rel="next">
									<span class="post-navigation__label">下一篇 →</span>
									<span class="post-navigation__title">{nextPost.title}</span>
								</a>
							)}
						</nav>
					)
				}
			</article>
		</main>
		<Footer />
		<script>
			const copyText = async (text: string) => {
				const clipboard = globalThis.navigator?.clipboard;
				if (clipboard?.writeText && globalThis.isSecureContext) {
					try {
						await clipboard.writeText(text);
						return;
					} catch {
						// Fall back to the selection-based copy path below.
					}
				}

				const activeElement = document.activeElement instanceof HTMLElement ? document.activeElement : null;
				const textarea = document.createElement('textarea');
				textarea.value = text;
				textarea.setAttribute('readonly', '');
				textarea.style.position = 'fixed';
				textarea.style.top = '-9999px';
				textarea.style.opacity = '0';
				document.body.append(textarea);
				let copied = false;
				try {
					textarea.focus();
					textarea.select();
					copied = document.execCommand('copy');
				} finally {
					textarea.remove();
					activeElement?.focus();
				}
				if (!copied) throw new Error('Copy failed');
			};

			const copySelectionFromCodeBlock = (pre: HTMLElement) => {
				const target = pre.querySelector('code') ?? pre;
				const selection = globalThis.getSelection?.();
				if (!selection) return 'failed';

				const range = document.createRange();
				range.selectNodeContents(target);
				selection.removeAllRanges();
				selection.addRange(range);

				return document.execCommand('copy') ? 'copied' : 'selected';
			};

			const enhanceCodeBlocks = () => {
				document.querySelectorAll('.prose pre').forEach((pre) => {
					if (!(pre instanceof HTMLElement) || pre.dataset.copyReady === 'true' || pre.closest('.code-block-copy')) return;

					const wrapper = document.createElement('div');
					wrapper.className = 'code-block-copy';

					const button = document.createElement('button');
					button.type = 'button';
					button.className = 'copy-code-button';
					button.textContent = '复制';
					button.setAttribute('aria-label', '复制代码');
					const status = document.createElement('span');
					status.className = 'sr-only';
					status.setAttribute('aria-live', 'polite');

					pre.dataset.copyReady = 'true';
					pre.parentNode?.insertBefore(wrapper, pre);
					wrapper.append(pre, button, status);

					button.addEventListener('click', async () => {
						const code = pre.querySelector('code')?.innerText ?? pre.innerText;
						status.textContent = '';
						try {
							await copyText(code.trimEnd());
							button.textContent = '已复制';
							button.setAttribute('aria-label', '代码已复制');
							status.textContent = '代码已复制';
							button.dataset.copyState = 'done';
						} catch {
							const fallbackState = copySelectionFromCodeBlock(pre);
							if (fallbackState === 'copied') {
								button.textContent = '已复制';
								button.setAttribute('aria-label', '代码已复制');
								status.textContent = '代码已复制';
								button.dataset.copyState = 'done';
							} else if (fallbackState === 'selected') {
								button.textContent = '已选中';
								button.setAttribute('aria-label', '代码已选中，请手动复制');
								status.textContent = '代码已选中，请按 Ctrl+C 手动复制';
								button.dataset.copyState = 'done';
							} else {
								button.textContent = '复制失败';
								button.setAttribute('aria-label', '复制代码失败');
								status.textContent = '复制失败，请选中代码后手动复制';
								button.dataset.copyState = 'error';
							}
						}

						window.setTimeout(() => {
							button.textContent = '复制';
							button.setAttribute('aria-label', '复制代码');
							delete button.dataset.copyState;
						}, 2200);
					});
				});
			};

			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', enhanceCodeBlocks, { once: true });
			} else {
				enhanceCodeBlocks();
			}
		</script>
	</body>
</html>
