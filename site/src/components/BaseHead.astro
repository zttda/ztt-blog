---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import { SITE_AUTHOR, SITE_TITLE, SITE_URL } from '../consts';
import theme from '../data/theme.json';
import { DARK_THEME_IDS, DEFAULT_THEME_ID, THEME_IDS } from '../data/themes';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
	type?: 'website' | 'article';
	schemaType?: 'website' | 'webpage' | 'collection' | 'profile' | 'article';
	robots?: string;
	pubDate?: Date;
	updatedDate?: Date;
	keywords?: string[];
	preloadHero?: { desktop: string; mobile?: string };
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
	title,
	description,
	image = FallbackImage,
	type = 'website',
	schemaType = type === 'article' ? 'article' : 'webpage',
	robots,
	pubDate,
	updatedDate,
	keywords = [],
	preloadHero,
} = Astro.props;
const brandSuffix = ` | ${SITE_TITLE}`;
const pageTitle = title === SITE_TITLE || title.endsWith(brandSuffix) ? title : `${title}${brandSuffix}`;
const optimizedSocialImage = image.src.includes('blog-xs')
	? null
	: await getImage({ src: image, width: 1200, format: 'webp', quality: 80 });
const socialImageSrc = image.src.includes('blog-xs')
	? '/uploads/theme/crayon-sticker-720.webp'
	: optimizedSocialImage?.src ?? image.src;
const absoluteImageURL = new URL(socialImageSrc, Astro.site);
const builtinFonts = {
	default: {
		stack: '"Atkinson", "Microsoft YaHei", "PingFang SC", sans-serif',
	},
	serif: {
		stack: '"Noto Serif SC", "Songti SC", "SimSun", serif',
	},
	wenkai: {
		stack: '"KaiTi", "STKaiti", "FangSong", "Microsoft YaHei", "PingFang SC", serif',
	},
	sans: {
		stack: '"Noto Sans SC", "Microsoft YaHei", "PingFang SC", sans-serif',
	},
	system: {
		stack: 'system-ui, "Microsoft YaHei", "PingFang SC", sans-serif',
	},
} as const;
type CustomFont = {
	id: string;
	family: string;
	url: string;
	format?: 'woff2' | 'woff' | 'truetype' | 'opentype';
	weight?: string;
};
const customFonts = (Array.isArray(theme.customFonts) ? (theme.customFonts as CustomFont[]) : []).filter(
	(font) =>
		font?.id &&
		typeof font.family === 'string' &&
		/^[\p{L}\p{N} _-]{1,80}$/u.test(font.family) &&
		typeof font.url === 'string' &&
		/^\/fonts\/custom\/[A-Za-z0-9._/-]+$/.test(font.url) &&
		(!font.format || ['woff2', 'woff', 'truetype', 'opentype'].includes(String(font.format))) &&
		(!font.weight || /^(?:normal|bold|[1-9]00)$/.test(String(font.weight))),
);
const customFontCss = customFonts
	.filter((font) => font?.family && font?.url)
	.map(
		(font) => `
@font-face {
	font-family: "${font.family}";
	src: url("${font.url}") format("${font.format || 'woff2'}");
	font-weight: ${font.weight || '400'};
	font-style: normal;
	font-display: swap;
}`,
	)
	.join('\n');
const fontStack = (value: string | undefined, fallback: string) => {
	const custom = customFonts.find((font) => font.id === value);
	if (custom?.family) return `"${custom.family}", ${fallback}`;
	return builtinFonts[value as keyof typeof builtinFonts]?.stack ?? fallback;
};
const bodyFontStack = fontStack(theme.bodyFont, builtinFonts.default.stack);
const headingFontStack = fontStack(theme.headingFont, bodyFontStack);
const navFontStack = fontStack(theme.navFont, bodyFontStack);
const homeTitleFontStack = fontStack(theme.homeTitleFont, headingFontStack);
const homeTextFontStack = fontStack(theme.homeTextFont, bodyFontStack);
const postTitleFontStack = fontStack(theme.postTitleFont, headingFontStack);
const postBodyFontStack = fontStack(theme.postBodyFont, bodyFontStack);
const footerFontStack = fontStack(theme.footerFont, bodyFontStack);
const activeThemeId = (THEME_IDS as readonly string[]).includes(theme.visualStyle)
	? theme.visualStyle
	: DEFAULT_THEME_ID;
const activeThemeIsDark = (DARK_THEME_IDS as readonly string[]).includes(activeThemeId);
let structuredData: Record<string, unknown>;
switch (schemaType) {
	case 'article':
		structuredData = {
			'@context': 'https://schema.org',
			'@type': 'BlogPosting',
			headline: title,
			description,
			image: absoluteImageURL.href,
			datePublished: pubDate?.toISOString(),
			dateModified: (updatedDate ?? pubDate)?.toISOString(),
			mainEntityOfPage: canonicalURL.href,
			author: { '@type': 'Person', name: SITE_AUTHOR },
			publisher: { '@type': 'Person', name: SITE_AUTHOR },
			...(keywords.length > 0 ? { keywords } : {}),
		};
		break;
	case 'website':
		structuredData = {
			'@context': 'https://schema.org',
			'@type': 'WebSite',
			name: SITE_TITLE,
			description,
			url: SITE_URL,
		};
		break;
	case 'profile':
		structuredData = {
			'@context': 'https://schema.org',
			'@type': 'ProfilePage',
			name: title,
			description,
			url: canonicalURL.href,
			mainEntity: { '@type': 'Person', name: SITE_AUTHOR },
		};
		break;
	default:
		structuredData = {
			'@context': 'https://schema.org',
			'@type': schemaType === 'collection' ? 'CollectionPage' : 'WebPage',
			name: title,
			description,
			url: canonicalURL.href,
			isPartOf: { '@type': 'WebSite', name: SITE_TITLE, url: SITE_URL },
		};
}
const structuredDataJson = JSON.stringify(structuredData).replace(/</g, '\\u003c');
const themeCss = `
${customFontCss}
:root {
	--font-body: ${bodyFontStack};
	--font-heading: ${headingFontStack};
	--font-nav: ${navFontStack};
	--font-home-title: ${homeTitleFontStack};
	--font-home-text: ${homeTextFontStack};
	--font-post-title: ${postTitleFontStack};
	--font-post-body: ${postBodyFontStack};
	--font-footer: ${footerFontStack};
}`;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=blog-1-tight-face" />
<link rel="icon" href="/favicon.ico?v=blog-1-tight-face" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Font preloads -->
<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin />
<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin />

<script
	is:inline
	define:vars={{
		activeThemeId,
		activeThemeIsDark,
		preloadHero: preloadHero ?? null,
	}}
>
	(() => {
		document.documentElement.classList.add('js');
		document.documentElement.dataset.style = activeThemeId;
		document.documentElement.style.colorScheme = activeThemeIsDark ? 'dark' : 'light';

		if (preloadHero?.desktop && activeThemeId === 'crayon-party') {
			const preload = document.createElement('link');
			preload.rel = 'preload';
			preload.as = 'image';
			preload.href = preloadHero.mobile && window.matchMedia('(max-width: 520px)').matches
				? preloadHero.mobile
				: preloadHero.desktop;
			preload.fetchPriority = 'high';
			document.head.append(preload);
		}
	})();
</script>

<style is:global set:html={themeCss} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{pageTitle}</title>
<meta name="title" content={pageTitle} />
<meta name="description" content={description} />
{robots && <meta name="robots" content={robots} />}
<meta name="author" content={SITE_AUTHOR} />
{keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:locale" content="zh_CN" />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={absoluteImageURL} />
<meta property="og:image:alt" content={`${title} 分享图片`} />
{type === 'article' && pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
{type === 'article' && updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={pageTitle} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={absoluteImageURL} />
<meta property="twitter:image:alt" content={`${title} 分享图片`} />

<script is:inline type="application/ld+json" set:html={structuredDataJson} />
