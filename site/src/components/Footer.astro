---
import footer from '../data/footer.json';

const today = new Date();
const year = today.getFullYear().toString();
const copyright = footer.copyright.replace('{year}', year);
const socialLinks = [
	{ id: 'douyin', label: '抖音', href: footer.douyinHref },
	{ id: 'bilibili', label: 'Bilibili', href: footer.bilibiliHref },
].filter((item) => item.href);
const secondaryLinks = [
	{ label: '归档', href: '/archive/' },
	{ label: '标签', href: '/tags/' },
	{ label: '搜索', href: '/search/' },
];
---

<footer>
	<div class="footer-inner">
		<p>{copyright}</p>
		<p>
			{footer.description}
			{footer.showRss && footer.rssHref && footer.rssLabel && (
				<>
					<span aria-hidden="true"> · </span>
					<a href={footer.rssHref}>{footer.rssLabel}</a>
				</>
			)}
		</p>
		<nav class="footer-nav" aria-label="更多内容">
			{secondaryLinks.map((item) => <a href={item.href}>{item.label}</a>)}
		</nav>
		{
			socialLinks.length > 0 && (
				<div class="footer-socials" aria-label="社交主页">
					{socialLinks.map((item) => (
						<a
							class={`social-link ${item.id}`}
							href={item.href}
							target="_blank"
							rel="noopener noreferrer"
							aria-label={`${item.label}（在新窗口打开）`}
						>
							{item.id === 'douyin' ? (
								<svg viewBox="0 0 24 24" aria-hidden="true">
									<path d="M14.8 3v10.1a4.7 4.7 0 1 1-4.7-4.7c.5 0 1 .1 1.4.2v3.2a1.8 1.8 0 1 0 0 1.3V3h3.3c.4 2.5 2.1 4.3 4.7 4.7v3.2c-1.8-.1-3.4-.8-4.7-2v.1z" />
								</svg>
							) : (
								<svg viewBox="0 0 24 24" aria-hidden="true">
									<path d="M8.1 4.2 10 6.4h4l1.9-2.2 1.5 1.3-.8.9h1.2A3.2 3.2 0 0 1 21 9.6v6.2a3.2 3.2 0 0 1-3.2 3.2H6.2A3.2 3.2 0 0 1 3 15.8V9.6a3.2 3.2 0 0 1 3.2-3.2h1.2l-.8-.9zM6.2 9A.7.7 0 0 0 5.5 9.7v6a.7.7 0 0 0 .7.7h11.6a.7.7 0 0 0 .7-.7v-6a.7.7 0 0 0-.7-.7zm2.6 2.8h2v2h-2zm4.4 0h2v2h-2z" />
								</svg>
							)}
						</a>
					))}
				</div>
			)
		}
	</div>
</footer>

<style>
	.footer-nav {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem 1rem;
		margin-top: 0.8rem;
	}

	.footer-nav a {
		display: inline-flex;
		min-width: 2.75rem;
		min-height: 2.75rem;
		align-items: center;
		justify-content: center;
		color: inherit;
		padding-inline: 0.2rem;
		text-underline-offset: 0.2em;
	}

	.footer-nav a:hover {
		color: var(--accent);
	}
</style>
